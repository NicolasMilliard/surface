{
  "name": "surface-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter surface dev",
    "build": "bun run --workspaces --if-present build",
    "lint": "eslint .",
    "preview": "bun run --filter surface preview"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.2",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.1",
    "vitest": "4.1.9"
  }
}
